rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Student Validation
    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'name', 'form', 'className', 'transportMode', 'hasLicense', 'licenseType']) &&
             data.keys().size() == 7 &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.form is string && data.form.size() <= 50 &&
             data.className is string && data.className.size() <= 50 &&
             data.transportMode in ['Motosikal', 'Kereta', 'Bas', 'Basikal', 'Jalan Kaki', 'Dihantar Penjaga', 'Lain-lain', 'Tiada'] &&
             data.hasLicense is bool &&
             data.licenseType in ['Motosikal (B2/B)', 'Kereta (D/DA)', 'Tiada'];
    }

    match /students/{studentId} {
      allow get, list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudent(request.resource.data) && request.resource.data.id == studentId;
      
      allow update: if isSignedIn() && isValidStudent(request.resource.data) && (
        // Action: Update Record
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['transportMode', 'hasLicense', 'licenseType']) &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.name == resource.data.name &&
        request.resource.data.form == resource.data.form &&
        request.resource.data.className == resource.data.className
      );
      
      allow delete: if false; // Prevention of accidental loss of data
    }
  }
}
